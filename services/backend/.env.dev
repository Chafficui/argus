# =============================================================================
# .env.dev — local development environment variables
# =============================================================================
# Copy to .env before running the backend locally:
#   cp .env.dev .env
#
# pydantic-settings reads .env automatically (see config.py model_config).
# All values here match the docker-compose.dev.yml defaults.
# =============================================================================

# App
ENVIRONMENT=development
LOG_LEVEL=debug
SECRET_KEY=dev-secret-key-change-in-prod-minimum-32-chars

# PostgreSQL (matches docker-compose.dev.yml postgres service)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=argus
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus-dev-password

# Milvus (matches docker-compose.dev.yml milvus service)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=argus_documents

# MinIO (matches docker-compose.dev.yml minio service)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=argus-minio
MINIO_SECRET_KEY=argus-minio-secret
MINIO_SECURE=false

# Ollama (matches docker-compose.dev.yml ollama service)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Keycloak (not in docker-compose.dev.yml — use mock auth for local dev)
KEYCLOAK_URL=http://localhost:8080/realms/argus
KEYCLOAK_AUDIENCE=argus-backend

# Dev auth bypass — skip JWT validation when ENVIRONMENT=development
# NEVER set this in production. See app/core/auth.py for safety checks.
DEV_AUTH_BYPASS=true
